# ProcedureGuard environment variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Azure identity (leave blank to use az login)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Azure AI Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Azure Blob Storage (Week 3)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER_SOP=sop-documents
AZURE_STORAGE_CONTAINER_VIDEO=manufacturing-videos
AZURE_STORAGE_CONTAINER_KEYFRAMES=keyframes

# App config
# Absolute path to local runs store. If blank, defaults to <workspace>/runs
PROCEDUREGUARD_RUNS_DIR=
LOG_LEVEL=INFO

# Agent 3 / AIMS — Incident Management (uses its own deployment var)
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
# Email notifications via Resend (optional — skip if unconfigured)
RESEND_API_KEY=
NOTIFY_FROM=onboarding@resend.dev
EMAIL_PRODUCTION_MANAGER=
EMAIL_QA_MANAGER=
EMAIL_SUPERVISOR=
EMAIL_QA_LOG=

# Agent 4 (QA Chat Agent)
# Override the deployment for the QA agent only; falls back to AZURE_OPENAI_DEPLOYMENT_NAME
QA_DEPLOYMENT_NAME=gpt-4.1-mini
PROVIDER_MODE=mcp
MCP_SERVER_COMMAND=python scripts/run_mcp_server.py
SQLITE_DB_PATH=src/local_data/procedureguard.db
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600

