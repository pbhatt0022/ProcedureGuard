# ============================================================
# ProcedureGuard — Environment Variables
# Copy this file to .env and fill in your values.
# Primary auth uses DefaultAzureCredential (az login locally).
# Keys are only needed as fallback if DefaultAzureCredential fails.
# NEVER commit .env to git.
# ============================================================

# ── Azure Identity ───────────────────────────────────────────
# Only needed if using a service principal instead of az login
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ── Azure AI Foundry ─────────────────────────────────────────
# Found in: AI Foundry portal → your project → Overview → API endpoint
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=https://<hub-name>.services.ai.azure.com/api/projects/<project-name>

# ── Azure OpenAI ─────────────────────────────────────────────
# Found in: AI Foundry portal → Deployments → your GPT-4o deployment
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
# Key only needed if not using DefaultAzureCredential
AZURE_OPENAI_API_KEY=

# ── Azure AI Document Intelligence ───────────────────────────
# Found in: Azure portal → your Document Intelligence resource → Keys and Endpoint
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://eastus.api.cognitive.microsoft.com/
# Key only needed if not using DefaultAzureCredential
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ── Azure AI Content Understanding ───────────────────────────
# Found in: Azure portal → your AI Services resource → Keys and Endpoint
# Must be in a region that supports Content Understanding (e.g. East US, West Europe)
AZURE_CONTENT_UNDERSTANDING_ENDPOINT=https://eastus.api.cognitive.microsoft.com/
# Key only needed if not using DefaultAzureCredential
AZURE_CONTENT_UNDERSTANDING_KEY=
# The analyzer ID you assign when creating the custom compliance analyzer
AZURE_CONTENT_UNDERSTANDING_ANALYZER_ID=procedureguard_compliance_v1

# ── Azure AI Search ───────────────────────────────────────────
# Found in: Azure portal → your AI Search resource → Overview → URL
# Use S1 tier minimum for multimodal embeddings
AZURE_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
# Key only needed if not using DefaultAzureCredential
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_INDEX_NAME=procedureguard-sop-visual-index

# ── Azure Cosmos DB ───────────────────────────────────────────
# Found in: Azure portal → your Cosmos DB account → Keys
AZURE_COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
# Key only needed if not using DefaultAzureCredential
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE_NAME=procedureguard
# Container for Agent 1 output (compliance checklists)
AZURE_COSMOS_CHECKLIST_CONTAINER=compliance-checklists
# Container for Agent 2 output (per-step verdicts + run metadata)
AZURE_COSMOS_VERDICTS_CONTAINER=verification-records
# Container for Agent 3 output (incidents flagged by compliance deviations)
AZURE_COSMOS_INCIDENTS_CONTAINER=incidents

# ── Azure Blob Storage ────────────────────────────────────────
# Found in: Azure portal → your Storage account → Settings → Endpoints
AZURE_STORAGE_ACCOUNT_NAME=<your-storage-account>
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
# Connection string only needed if not using DefaultAzureCredential
AZURE_STORAGE_CONNECTION_STRING=
# Container names — create these in the portal before running the pipeline
AZURE_STORAGE_CONTAINER_SOP=sop-documents
AZURE_STORAGE_CONTAINER_VIDEO=manufacturing-videos
AZURE_STORAGE_CONTAINER_KEYFRAMES=keyframes

# ── Application Config ────────────────────────────────────────
# Confidence score below which Agent 2 retries with adjacent video segments
CONFIDENCE_THRESHOLD=0.7
LOG_LEVEL=INFO
