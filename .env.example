# ProcedureGuard — environment variables
# Copy this file to .env and fill in your values.
# ALSO copy to frontend/.env.local so Next.js picks up the same values.
# NEVER commit either file to git.

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Classic Azure OpenAI endpoint:  https://<resource>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=
# Leave AZURE_OPENAI_API_KEY blank — system authenticates via `az login` (DefaultAzureCredential).
# Filling it in with a Foundry key will cause 401 errors.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Agent 1, 2 & 4 — use the deployed name from your Azure OpenAI resource (e.g. gpt-4o)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# Agent 3 — incident management
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Agent 4 — compliance chat assistant (leave blank to fall back to AZURE_OPENAI_DEPLOYMENT_NAME)
QA_DEPLOYMENT_NAME=

# ── Azure AI Document Intelligence ────────────────────────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ── Azure Blob Storage ────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_URL=
AZURE_STORAGE_CONTAINER_SOP=sop-documents
AZURE_STORAGE_CONTAINER_VIDEO=manufacturing-videos
AZURE_STORAGE_CONTAINER_KEYFRAMES=keyframes

# ── Azure identity (only needed for service-principal / CI auth) ──────────────
# Leave blank if using `az login` or DefaultAzureCredential interactively.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# ── Agent 3 email notifications (optional) ────────────────────────────────────
RESEND_API_KEY=
NOTIFY_FROM=onboarding@resend.dev
EMAIL_PRODUCTION_MANAGER=
EMAIL_QA_MANAGER=
EMAIL_SUPERVISOR=
EMAIL_QA_LOG=

# ── Agent 4 MCP / session config ─────────────────────────────────────────────
PROVIDER_MODE=mcp
MCP_SERVER_COMMAND=python scripts/run_mcp_server.py
SQLITE_DB_PATH=src/local_data/procedureguard.db
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=3600

# ── App config ────────────────────────────────────────────────────────────────
# Absolute path to local runs store. Leave blank to use <workspace>/runs.
PROCEDUREGUARD_RUNS_DIR=
LOG_LEVEL=INFO
